uv.lock

# ETL generated artifacts
etl/output/
etl/output_*/
etl/.cache/
experiments/**/output/
experiments/**/.cache/
*.parquet
*.zip

# Allow small sample data committed intentionally
!web/public/samples/*.parquet
!experiments/**/samples/*.parquet
!etl/samples/*.parquet
