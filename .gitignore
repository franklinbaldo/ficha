# These are Python build artifacts. Scope them under etl/ so we don't
# accidentally ignore directories with the same name elsewhere (notably
# web/src/lib/).
etl/build/
etl/develop-eggs/
etl/downloads/
etl/eggs/
etl/.eggs/
etl/lib/
etl/lib64/
etl/parts/
etl/sdist/
